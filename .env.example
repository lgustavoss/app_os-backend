# Copie para `.env` (não commite). Em produção: CORS/CSRF, SECRET_KEY, etc. (checklist de deploy da equipa).

SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

USE_TLS=False
BEHIND_REVERSE_PROXY=False

# Produção: defina origens HTTPS explícitas (substitui defaults localhost)
# CORS_ALLOWED_ORIGINS=https://app.exemplo.com
# CORS_ALLOWED_ORIGINS_EXTRA=
# CSRF_TRUSTED_ORIGINS=https://app.exemplo.com
# CSRF_TRUSTED_ORIGINS_EXTRA=

# OpenAPI/Swagger desligado em produção por padrão; ative só se necessário
# API_DOCS_ENABLED=False

# Se não usar Nginx a servir ficheiros: True (menos recomendado)
# SERVE_MEDIA_VIA_DJANGO=False

# Cookies (cross-site só com HTTPS)
# SESSION_COOKIE_SAMESITE=Lax
# CSRF_COOKIE_SAMESITE=

# Database
DB_NAME=app_os
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432

# Cache / rate limit / sessão
# CACHE_URL=redis://redis:6379/1
# SESSION_STORE=db
# LOGIN_RATE_LIMIT=20/m

# LOG_JSON=True
# SENTRY_DSN=
